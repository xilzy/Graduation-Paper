% % fused_path = strcat('./DATA/D2FNet4/',name,'/mri-ct/',name1,'/');
% % fused_path = strcat('./DATA/D2FNet4/',name,'/mri-pet/',name1,'/');
% fused_path = strcat('./DATA/D2FNet4/',name,'/mri-spect/',name1,'/');

    for i =1:1:nums
        %读取源图像对
%         source_ir  = ['./test_imgs/mri-ct/mri/',num2str(i),'.png'];
%         source_vis = ['./test_imgs/mri-ct/ct/',num2str(i),'.png'];
%         source_ir  = ['./test_imgs/mri-pet/mri/',num2str(i),'.png'];
%         source_vis = ['./test_imgs/mri-pet/pet/',num2str(i),'.png'];
%         source_ir  = ['./test_imgs/mri-spect/mri/',num2str(i),'.png'];
