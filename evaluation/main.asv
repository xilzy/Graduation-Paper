n=length(fusion_name(:));                    %外层循环的个数 
for fm=1:n               %最外层控制不同方法的文件夹
name = fusion_name{fm};
disp(name);
%%% 内部步数比较
% fused_path = strcat('./DATA/D2FNet4/modify11/mri-ct/',name,'/'); %拼接融合图像存放路径
% fused_path = strcat('./DATA/D2FNet4/modify11/mri-pet/',name,'/');
