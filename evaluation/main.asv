%消融实验
fused_path = strcat('./DATA/D2FNet4/',name,'/mri-ct/2400/');
% fused_path = strcat('./DATA/D2FNet4/',name,'/mri-pet/2400/');
% fused_path = strcat('./DATA/D2FNet4/',name,'/mri-spect/2400/');

%联合梯度系数实验
% second_name={'3600','4000','5826','4800','4400'};
% second_name={'7500','6000','7500','7500','8070'};
% second_name={'8568','7500','8568','7500','2800'};
